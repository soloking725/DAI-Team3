# Qwen API configuration
# This app uses the SAME API key and endpoint as Hermes Agent.
#
# Hermes Agent config (from ~/.hermes/config.yaml):
#   provider: custom
#   base_url: http://litellm.colby.edu:4000/v1
#   api_key: sk-...
#
# Set these environment variables in your .env file:

QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=http://litellm.colby.edu:4000/v1

# Optional: Override the model name (default: qwen-3.6-27b)
QWEN_MODEL=qwen-3.6-27b
